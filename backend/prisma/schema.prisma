// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum TableStatus {
  AVAILABLE // ว่าง
  OCCUPIED // มีลูกค้านั่งอยู่
  RESERVED // จองแล้ว
  CLEANING // รอทำความสะอาด
}

enum SessionStatus {
  ACTIVE // กำลังทานอยู่
  CLOSED // ปิดโต๊ะแล้ว
  EXPIRED // หมดเวลา
}

enum OrderStatus {
  PENDING // รอยืนยัน
  CONFIRMED // ยืนยันแล้ว
  CANCELLED // ยกเลิก
}

enum ItemStatus {
  PENDING // รอดำเนินการ
  PREPARING // กำลังทำ
  SERVED // เสิร์ฟแล้ว
  VOIDED // ยกเลิก
}

// --- 1. กลุ่มจัดการผู้ใช้งานและสิทธิ์ (User & Access Control) ---

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model User {
  id           String    @id @default(uuid())
  roleId       Int
  role         Role      @relation(fields: [roleId], references: [id])
  username     String    @unique
  passwordHash String
  fullName     String
  avatarUrl    String?
  isActive     Boolean   @default(true)
  refreshToken String?
  invoices     Invoice[]
  voidedLogs   VoidLog[]
}

// --- 2. กลุ่มตั้งค่าเมนูและการแยกแผนกครัว (Menu & Kitchen Configuration) ---

/// [Socket] หน้าจอ KDS (Kitchen Display System) จะต้อง listen แผนกของตัวเอง
model KitchenSection {
  id         Int         @id @default(autoincrement())
  name       String      @unique // เช่น HOT_KITCHEN, COLD_KITCHEN
  menuItems  MenuItem[]
  orderItems OrderItem[]
}
/// หมวดหมู่ของอาหาร เช่น เนื้อวัว, ลูกชิ้น, ผัก, ขนมหวาน
model Category {
  id        Int        @id @default(autoincrement())
  name      String
  iconUrl   String?
  menuItems MenuItem[]
}

/// ระดับราคาบุฟเฟต์ เช่น Silver 399, Gold 599, Platinum 799
model Tier {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  priceAdult    Decimal
  priceChild    Decimal
  timeLimit     Int            @default(90)
  sessions      Session[]
  tierMenuItems TierMenuItem[]
}

/// รายการอาหารแต่ละอย่าง พร้อมรูปภาพและจุดที่ต้องทำอาหาร
model MenuItem {
  id          String         @id @default(uuid())
  categoryId  Int
  category    Category       @relation(fields: [categoryId], references: [id])
  kitchenId   Int
  kitchen     KitchenSection @relation(fields: [kitchenId], references: [id])
  name        String
  imageUrl    String?
  isAvailable Boolean        @default(true) // [Socket] แจ้งลูกค้า/พนักงาน ทันทีเมื่อของหมด
  tierItems   TierMenuItem[]
  orderItems  OrderItem[]
  recipe      Recipe[]
}

/// ตารางกลางที่กำหนดว่า "ระดับราคา (Tier) ไหน" สามารถสั่ง "อาหารชนิดใด" ได้บ้าง
model TierMenuItem {
  tierId     Int
  menuItemId String
  tier       Tier     @relation(fields: [tierId], references: [id])
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@id([tierId, menuItemId])
}

// --- 3. กลุ่มจัดการโต๊ะและรอบการนั่งทาน (Table & Session Management) ---
/// ข้อมูลโต๊ะในร้านและสถานะปัจจุบัน (ว่าง, มีลูกค้า, รอทำความสะอาด)
model Table {
  id       Int         @id @default(autoincrement())
  number   String      @unique
  zone     String?
  status   TableStatus @default(AVAILABLE) // [Socket] อัปเดตผังโต๊ะที่หน้า POS/พนักงาน ทันทีที่มีการเปลี่ยนสถานะ
  sessions Session[]
}

/// รอบการนั่งทานของลูกค้า เชื่อมโยงกับโต๊ะและ QR Token สำหรับสั่งอาหาร
model Session {
  id        String        @id @default(uuid())
  tableId   Int
  table     Table         @relation(fields: [tableId], references: [id])
  tierId    Int
  tier      Tier          @relation(fields: [tierId], references: [id])
  qrToken   String        @unique
  adultCount Int          @default(1) // จำนวนผู้ใหญ่
  childCount Int          @default(0) // จำนวนเด็ก
  startTime DateTime      @default(now())
  endTime   DateTime // [Socket] ส่ง event แจ้งเตือนลูกค้า/พนักงาน เมื่อเหลือ 15 นาที หรือหมดเวลา
  status    SessionStatus @default(ACTIVE) // [Socket] แจ้งเตือนเมื่อมีการปิดโต๊ะหรือเรียกเช็คบิล
  orders    Order[]
  invoices  Invoice[]
}

// --- 4. กลุ่มการสั่งอาหารและสถานะออเดอร์ (Ordering System) ---
/// หัวข้อออเดอร์ในแต่ละครั้งที่ลูกค้ากด "ยืนยันการสั่ง"
model Order {
  id        String      @id @default(uuid())
  sessionId String
  session   Session     @relation(fields: [sessionId], references: [id])
  status    OrderStatus @default(PENDING) // [Socket] แจ้งเตือนออเดอร์ใหม่เข้าครัว (New Order Alert)
  createdAt DateTime    @default(now())
  items     OrderItem[]
}

/// รายการอาหารแต่ละรายการในออเดอร์นั้นๆ พร้อมระบุครัวที่ต้องรับผิดชอบ
model OrderItem {
  id         String         @id @default(uuid())
  orderId    String
  order      Order          @relation(fields: [orderId], references: [id])
  menuItemId String
  menuItem   MenuItem       @relation(fields: [menuItemId], references: [id])
  kitchenId  Int
  kitchen    KitchenSection @relation(fields: [kitchenId], references: [id])
  quantity   Int
  status     ItemStatus     @default(PENDING) // [Socket] สำคัญมาก: แจ้งลูกค้าเมื่ออาหารเปลี่ยนเป็น 'กำลังทำ' หรือ 'เสิร์ฟแล้ว'
  voidLog    VoidLog?
}

// --- 5. กลุ่มคลังวัตถุดิบและระบบบัญชี (Inventory & Finance) ---

/// ข้อมูลวัตถุดิบในคลังเพื่อใช้ตัดสต็อก
model Ingredient {
  id           Int      @id @default(autoincrement())
  name         String
  unit         String
  currentStock Decimal // [Socket] แจ้งเตือน Admin/Owner ทันทีเมื่อ Stock ต่ำกว่าจุดวิกฤต
  imageUrl     String?
  recipes      Recipe[]
}

/// สูตรอาหาร กำหนดว่าเมนู 1 จาน ใช้ชิ้นส่วนวัตถุดิบอะไรบ้างและปริมาณเท่าไหร่
model Recipe {
  menuItemId   String
  ingredientId Int
  quantityUsed Decimal
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id])
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  @@id([menuItemId, ingredientId])
}

/// ข้อมูลใบชำระเงินและสรุปยอดหลังจากลูกค้าทานเสร็จ
model Invoice {
  id              String   @id @default(uuid())
  sessionId       String
  session         Session  @relation(fields: [sessionId], references: [id])
  totalAmount     Decimal
  discount        Decimal  @default(0)
  netAmount       Decimal // [Socket] แจ้งยอดเงินเข้าที่หน้า Dashboard ของ Owner ทันที
  paymentMethod   String
  promptPayNumber String?  // เบอร์โทรศัพท์ PromptPay (สำหรับ QR_CODE)
  createdBy       String
  user            User     @relation(fields: [createdBy], references: [id])
  createdAt       DateTime @default(now())
}

/// บันทึกเหตุผลการยกเลิกอาหาร เพื่อใช้ตรวจสอบย้อนหลังป้องกันการทุจริต
model VoidLog {
  id          Int       @id @default(autoincrement())
  orderItemId String    @unique
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  reason      String
  approvedBy  String
  manager     User      @relation(fields: [approvedBy], references: [id])
  createdAt   DateTime  @default(now()) // [Socket] แจ้งเตือนผู้จัดการเมื่อมีรายการขอ Void
}